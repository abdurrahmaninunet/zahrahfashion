# ─────────────────────────────────────────────────────────────────────────────
# Zahrah — production environment. Copy per service; never commit real values.
# In ECS, prefer AWS Secrets Manager / SSM for secrets (marked 🔒 below).
# ─────────────────────────────────────────────────────────────────────────────

# == API service =============================================================
NODE_ENV=production                      # REQUIRED — disables all dev fallbacks (on-screen codes, etc.)
PORT=4000

# Postgres (RDS). 🔒
DATABASE_URL=postgresql://zahrah:CHANGE_ME@zahrah-db.xxxx.eu-west-1.rds.amazonaws.com:5432/zahrah?schema=public&sslmode=require

# Redis (ElastiCache) — REQUIRED when running more than one API task (shared
# OTP / pending-auth state). Omit only for a single-instance setup. 🔒
REDIS_URL=redis://zahrah-redis.xxxx.cache.amazonaws.com:6379

# Sessions & security 🔒
SESSION_COOKIE_NAME=zahrah_admin_session
TRACKING_SECRET=CHANGE_ME_long_random_string   # guest order-tracking token signing

# Payments — Paystack (LIVE keys). 🔒  Also set payments.gateway_mode=live in admin Settings.
PAYSTACK_SECRET_KEY=sk_live_CHANGE_ME

# Email — Resend. 🔒  Verify zahrahfashion.com as a sending domain in Resend first.
RESEND_API_KEY=re_CHANGE_ME
RESEND_FROM_EMAIL=Zahrah Fashion <no-reply@zahrahfashion.com>
SUPPORT_EMAIL=hello@zahrahfashion.com          # contact-form messages are sent here

# Media — S3 + CloudFront. Credentials come from the ECS TASK ROLE (no keys here).
AWS_REGION=eu-west-1
S3_MEDIA_BUCKET=zahrah-media
MEDIA_PUBLIC_URL=https://cdn.zahrahfashion.com  # CloudFront distribution domain

# Google sign-in (optional). 🔒  Leave unset to keep the button disabled.
GOOGLE_CLIENT_ID=

# Public URLs used in emails / callbacks
ADMIN_URL=https://admin.zahrahfashion.com
STOREFRONT_URL=https://zahrahfashion.com

# == Storefront service ======================================================
# API_URL — internal URL of the API service (service discovery or internal ALB).
API_URL=http://zahrah-api.internal:4000
# Baked into the client bundle at BUILD time (docker build --build-arg …):
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# == Admin service ===========================================================
API_URL=http://zahrah-api.internal:4000

# == Seeding =================================================================
# DO NOT set in production — leaving it unset seeds a BLANK store (no demo products).
# SEED_DEMO=true

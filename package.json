{
  "name": "zahrah-fashion",
  "private": true,
  "version": "0.1.0",
  "description": "Zahrah Fashion ecommerce platform — admin portal, API, storefront",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace=@zahrah/api",
    "dev:admin": "npm run dev --workspace=@zahrah/admin",
    "build": "npm run build --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace=@zahrah/api",
    "prisma:migrate": "npm run prisma:migrate --workspace=@zahrah/api",
    "seed": "npm run seed --workspace=@zahrah/api",
    "dev": "concurrently -n api,admin,store -c blue,green,yellow \"npm:dev:api\" \"npm:dev:admin\" \"npm:dev:store\"",
    "dev:store": "npm run dev --workspace=@zahrah/storefront"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0"
  }
}

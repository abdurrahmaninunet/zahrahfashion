DATABASE_URL="postgresql://zahrah:zahrah_dev@localhost:5432/zahrah?schema=public"
PORT=4310
SESSION_COOKIE_NAME=zahrah_admin_session
UPLOADS_DIR=./uploads
ADMIN_ORIGIN=http://localhost:4311

# ── Customer auth: email OTP + password reset (via Resend) ─────────────────
# Registration & password-reset send a 6-digit code by email via Resend.
# Without RESEND_API_KEY, the code is returned in the API response in dev only
# (never when NODE_ENV=production) so you can still test the flow.
RESEND_API_KEY=
# Must be a verified domain sender, e.g. "Zahrah Fashion <no-reply@yourdomain.com>".
# For quick testing you can use Resend's sandbox sender: onboarding@resend.dev
RESEND_FROM_EMAIL=Zahrah Fashion Hub <onboarding@resend.dev>

# ── Customer auth: Google sign-in (set up later) ───────────────────────────
# OAuth 2.0 "Web application" client ID from the Google Cloud Console.
GOOGLE_CLIENT_ID=

# ── Payments: Paystack ─────────────────────────────────────────────────────
# Secret key from your Paystack dashboard (sk_test_… for testing, sk_live_… for
# production). Without it, checkout shows a dev "simulate payment" button.
PAYSTACK_SECRET_KEY=
# Storefront base URL used for the Paystack return/callback. If unset, the API
# uses the browser origin sent with the order (fine for local dev).
STOREFRONT_URL=http://localhost:3000

# Secret used to sign guest order-tracking links. Set a long random value in prod.
TRACKING_SECRET=change-me-in-production
